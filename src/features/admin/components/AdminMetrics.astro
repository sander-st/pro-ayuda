---
import MetricCard from '../../../components/ui/MetricCard.astro';
import { formatMoneda } from '../utils/metrics';

interface Props {
  recaudacionReal: number;
  porcionesTotales: number;
  totalDelivery: number;
  totalRecojo: number;
}
const { recaudacionReal, porcionesTotales, totalDelivery, totalRecojo } = Astro.props;
---
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <MetricCard 
    title="Recaudación Real" 
    value={formatMoneda(recaudacionReal)} 
    description="Solo pagos verificados" 
    valueColorClass="text-emerald-600" 
  />
  <MetricCard 
    title="Porciones Vendidas" 
    value={porcionesTotales} 
    description="Total general reservado" 
    valueColorClass="text-slate-900" 
  />
  <MetricCard 
    title="Envíos Delivery" 
    value={totalDelivery} 
    description="Pedidos para despachar" 
    valueColorClass="text-blue-600" 
  />
  <MetricCard 
    title="Recojo Local" 
    value={totalRecojo} 
    description="Entregas en puerta" 
    valueColorClass="text-amber-500" 
  />
</div>
