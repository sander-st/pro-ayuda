---
import { prisma } from '../lib/db';
import { calcularMetricas } from '../features/admin/utils/metrics';
import AdminMetrics from '../features/admin/components/AdminMetrics.astro';
import AdminTable from '../features/admin/components/AdminTable.astro';

// Inicializar configuración si no existe
let config = await prisma.adminConfig.findUnique({ where: { id: 1 } });
if (!config) {
  config = await prisma.adminConfig.create({ data: { id: 1, password: "PRO-SALUD" } });
}

let isAuthenticated = false;
let loginError = "";
let settingsMessage = "";
let isSettingsOpen = false;

// Verificamos si ya hay una sesión activa en las cookies
const authCookie = Astro.cookies.get('admin_auth');
if (authCookie?.value === 'authenticated') {
  isAuthenticated = true;
}

if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const action = data.get('action');

  if (action === 'login') {
    const password = data.get('password');
    if (password === config.password) {
      Astro.cookies.set('admin_auth', 'authenticated', { path: '/' });
      isAuthenticated = true;
    } else {
      loginError = "Contraseña incorrecta. Inténtalo de nuevo.";
    }
  } else if (action === 'change_password') {
    if (isAuthenticated) {
      const newPassword = data.get('newPassword')?.toString();
      if (newPassword && newPassword.length >= 4) {
        await prisma.adminConfig.update({
          where: { id: 1 },
          data: { password: newPassword }
        });
        settingsMessage = "Contraseña actualizada exitosamente.";
      } else {
        settingsMessage = "La contraseña debe tener al menos 4 caracteres.";
      }
      isSettingsOpen = true; // Mantener abierto el modal de ajustes
    }
  } else if (action === 'logout') {
    Astro.cookies.delete('admin_auth', { path: '/' });
    isAuthenticated = false;
  }
}

// Solo si está autenticado cargamos los datos reales
let reservas = [];
let metricas = { totalRecaudado: 0, totalPolladas: 0, pendientesPago: 0, pendientesEntrega: 0, tasaRecojo: 0 };

if (isAuthenticated) {
  try {
    reservas = await prisma.reserva.findMany({
      orderBy: { fechaCreacion: 'desc' }
    });
    metricas = calcularMetricas(reservas);
  } catch (error) {
    console.error("Error fetching reservas:", error);
  }
}
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard Admin - Pollada Solidaria</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <style>
    @import "../styles/global.css";
    .glassmorphism {
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.4);
    }
  </style>
</head>
<body class="bg-slate-50 min-h-screen text-slate-800 font-sans p-4 sm:p-8">

  {!isAuthenticated ? (
    <div class="min-h-[80vh] flex items-center justify-center">
      <div class="max-w-md w-full mx-auto bg-white p-10 rounded-3xl shadow-[0_20px_60px_rgb(0,0,0,0.05)] border border-slate-100 relative overflow-hidden group">
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-orange-100 rounded-full blur-3xl opacity-50 group-hover:bg-orange-200 transition-colors duration-500"></div>
        <div class="absolute -bottom-24 -left-24 w-48 h-48 bg-rose-100 rounded-full blur-3xl opacity-50 group-hover:bg-rose-200 transition-colors duration-500"></div>
        
        <div class="relative z-10 text-center mb-8">
          <div class="w-16 h-16 bg-gradient-to-tr from-orange-500 to-rose-500 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg shadow-orange-500/30 transform rotate-3 hover:rotate-6 transition-transform">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8V7a4 4 0 00-8 0v4h8z"></path></svg>
          </div>
          <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Acceso Admin</h1>
          <p class="text-slate-500 font-medium mt-2">Ingresa tu contraseña para continuar</p>
        </div>

        <form method="POST" class="relative z-10 space-y-6">
          <input type="hidden" name="action" value="login" />
          
          <div>
            <label for="password" class="block text-sm font-bold text-slate-700 mb-2">Contraseña de acceso</label>
            <input 
              type="password" 
              id="password" 
              name="password" 
              required 
              placeholder="Ingresa la contraseña"
              class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:outline-none focus:ring-2 focus:ring-orange-500/50 focus:border-orange-500 transition-all font-medium placeholder:font-normal placeholder:text-slate-400"
            />
          </div>

          {loginError && (
            <div class="bg-red-50 text-red-600 text-sm font-medium px-4 py-3 rounded-lg border border-red-100 animate-pulse">
              {loginError}
            </div>
          )}

          <button 
            type="submit" 
            class="w-full bg-slate-900 hover:bg-slate-800 text-white font-bold py-4 rounded-xl shadow-lg shadow-slate-900/20 transform hover:-translate-y-1 transition-all active:translate-y-0"
          >
            Ingresar al Panel
          </button>
        </form>
      </div>
    </div>
  ) : (
    <div class="max-w-6xl mx-auto">
      <header class="flex flex-col sm:flex-row justify-between items-start sm:items-end mb-8 gap-4">
        <div>
          <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Panel de Control</h1>
          <p class="text-slate-500 font-medium mt-1">Gestión logística y financiera</p>
        </div>
        
        <div class="flex gap-3">
          <button 
            onclick="document.getElementById('settings-modal').classList.remove('hidden')"
            class="px-5 py-2.5 bg-white border border-slate-200 text-slate-700 font-bold rounded-xl hover:bg-slate-50 hover:border-slate-300 transition-all flex items-center gap-2 shadow-sm"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            Ajustes
          </button>
          <form method="POST" class="m-0 p-0">
            <input type="hidden" name="action" value="logout" />
            <button 
              type="submit"
              class="px-5 py-2.5 bg-rose-50 border border-rose-100 text-rose-600 font-bold rounded-xl hover:bg-rose-100 hover:border-rose-200 transition-all flex items-center gap-2 shadow-sm"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
              Salir
            </button>
          </form>
        </div>
      </header>

      <!-- Métricas -->
      <AdminMetrics {...metricas} />

      <!-- Tabla -->
      <AdminTable reservas={reservas} />
      
      <!-- Settings Modal -->
      <div id="settings-modal" class={`fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/40 backdrop-blur-sm ${isSettingsOpen ? '' : 'hidden'}`}>
        <div class="bg-white rounded-3xl shadow-2xl max-w-md w-full overflow-hidden border border-slate-100 transform transition-all">
          <div class="px-6 py-5 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
            <h3 class="text-xl font-bold text-slate-800 flex items-center gap-2">
              <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8V7a4 4 0 00-8 0v4h8z"></path></svg>
              Cambiar Contraseña
            </h3>
            <button onclick="document.getElementById('settings-modal').classList.add('hidden')" class="text-slate-400 hover:text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-full p-2 transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
          </div>
          
          <div class="p-6">
            <form method="POST" class="space-y-5">
              <input type="hidden" name="action" value="change_password" />
              
              <div>
                <label for="newPassword" class="block text-sm font-bold text-slate-700 mb-2">Nueva Contraseña</label>
                <input 
                  type="password" 
                  id="newPassword" 
                  name="newPassword" 
                  required 
                  minlength="4"
                  placeholder="Mínimo 4 caracteres"
                  class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:outline-none focus:ring-2 focus:ring-orange-500/50 focus:border-orange-500 transition-all"
                />
              </div>

              {settingsMessage && (
                <div class={`text-sm font-medium px-4 py-3 rounded-lg border ${settingsMessage.includes('exitosamente') ? 'bg-green-50 text-green-600 border-green-100' : 'bg-red-50 text-red-600 border-red-100'}`}>
                  {settingsMessage}
                </div>
              )}

              <button 
                type="submit" 
                class="w-full bg-orange-500 hover:bg-orange-600 text-white font-bold py-3 rounded-xl shadow-lg shadow-orange-500/20 transform hover:-translate-y-0.5 transition-all"
              >
                Actualizar Contraseña
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  )}

  {isAuthenticated && (
    <script>
      import { setupAdminClient } from '../features/admin/scripts/adminClient';
      document.addEventListener('DOMContentLoaded', setupAdminClient);
      
      // Cerrar modal al hacer clic fuera
      const modal = document.getElementById('settings-modal');
      if (modal) {
        modal.addEventListener('click', (e) => {
          if (e.target === modal) {
            modal.classList.add('hidden');
          }
        });
      }
    </script>
  )}
</body>
</html>
