---
import Layout from '../layouts/Layout.astro';
import TicketCanvas from '../components/TicketCanvas.astro';
import TicketHeader from '../features/reservas/components/TicketHeader.astro';
import PaymentDetails from '../features/reservas/components/PaymentDetails.astro';
import ReservationForm from '../features/reservas/components/ReservationForm.astro';
---

<Layout title="Pollada Solidaria - Reserva tu Ticket">
  <!-- Cabecera del Ticket -->
  <TicketHeader />

  <!-- Línea de corte -->
  <div class="px-4 bg-white relative">
    <div class="ticket-tear"></div>
  </div>

  <!-- Detalles de Pago -->
  <PaymentDetails />

  <!-- Línea de corte -->
  <div class="px-4 bg-white relative">
    <div class="ticket-tear"></div>
  </div>

  <!-- Formulario -->
  <ReservationForm />

  <!-- Cutout circles for bottom ticket effect -->
  <div class="absolute -bottom-3 -left-3 w-6 h-6 bg-ticket-bg rounded-full z-10"></div>
  <div class="absolute -bottom-3 -right-3 w-6 h-6 bg-ticket-bg rounded-full z-10"></div>
  
  <TicketCanvas />
</Layout>

<script>
  import { setupReservasClient } from '../features/reservas/scripts/reservasClient';
  document.addEventListener('DOMContentLoaded', setupReservasClient);
</script>

